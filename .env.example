# --- Static site (required to build & deploy) ---
# Canonical base URL — baked into sitemap, canonical tags, hreflang, OG images.
# Local: http://localhost:3000  |  Prod: https://qstech.vn
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Contact form / leads (Phase 5 — not wired or tested yet) ---
# Only needed once the leads Pages Function ships. Static build ignores these.
#
# Resend — admin email notification on new lead
# RESEND_API_KEY=
# RESEND_FROM=
# LEAD_NOTIFY_EMAIL=
#
# Upstash Redis — rate-limit the contact form
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
#
# CRM webhook — leave empty: leads still arrive via Resend email when unset
# CRM_WEBHOOK_URL=
