# `/` is intentionally NOT redirected at the edge: the prerendered index.html
# (app/page.tsx) detects the visitor's locale client-side (saved choice in
# localStorage, else browser language) and redirects to /vi/ or /en/. A <meta
# refresh> to /vi/ is the no-JS fallback.

# Old un-prefixed VI routes → /vi/* (preserve SEO)
/products                  /vi/products/              301
/products/*                /vi/products/:splat        301
/services                  /vi/services/              301
/services/*                /vi/services/:splat        301
/news                      /vi/news/                  301
/news/*                    /vi/news/:splat            301
/applications              /vi/applications/          301
/applications/*            /vi/applications/:splat    301
# No `/downloads/*` splat: static assets (hero + PDFs) live under public/downloads/
# and a splat here would 301 them to a non-existent /vi/downloads/* and 404.
/downloads                 /vi/downloads/             301
/about                     /vi/about/                 301
/contact                   /vi/contact/               301
/search                    /vi/search/                301

# Renamed CNC machine: QSM-125 -> QSM-215 (model and slug renamed)
/vi/cnc/qsm-125            /vi/cnc/qsm-215            301
/en/cnc/qsm-125            /en/cnc/qsm-215            301
