# --- Static site (required to build & deploy) ---
# Canonical base URL — baked into sitemap, canonical tags, hreflang, OG images.
# Local: http://localhost:3000  |  Prod: https://qstech.vn
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Contact / inquiry forms → CRM public lead endpoint ---
# Base URL of the CRM API. Forms POST to {base}/public/leads (no auth,
# rate-limited 5/min/IP). Public var → inlined into the static client bundle.
# The CRM CORS allowlist must include the deployed site origin.
# Default (when unset): https://crm.qstcnc.com/api/v1
NEXT_PUBLIC_CRM_API_BASE=https://crm.qstcnc.com/api/v1
