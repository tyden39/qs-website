# `/` is intentionally NOT redirected at the edge: the prerendered index.html
# (app/page.tsx) detects the visitor's locale client-side (saved choice in
# localStorage, else browser language) and redirects to /vi/ or /en/. A <meta
# refresh> to /vi/ is the no-JS fallback.

# Old un-prefixed VI routes → /vi/* (preserve SEO)
/products                  /vi/electronics/           301
/products/*                /vi/electronics/:splat     301
/services                  /vi/services/              301
/services/*                /vi/services/:splat        301
/news                      /vi/news/                  301
/news/*                    /vi/news/:splat            301
/applications              /vi/applications/          301
/applications/*            /vi/applications/:splat    301
# No `/downloads/*` splat: static assets (hero + PDFs) live under public/downloads/
# and a splat here would 301 them to a non-existent /vi/downloads/* and 404.
/downloads                 /vi/downloads/             301
/about                     /vi/about/                 301
/contact                   /vi/contact/               301
/search                    /vi/search/                301

# Renamed routes: /products -> /electronics, /cnc -> /machine-building
# (section titles changed to Electronics / Machine Building). Exact + splat
# pairs because `/path/*` does not match `/path` itself.
/vi/products               /vi/electronics/               301
/vi/products/*             /vi/electronics/:splat         301
/en/products               /en/electronics/               301
/en/products/*             /en/electronics/:splat         301
# Renamed CNC machine QSM-125 -> QSM-215 listed before the /cnc/* splats so the
# old slug lands on the new page in one hop.
/vi/cnc/qsm-125            /vi/machine-building/qsm-215   301
/en/cnc/qsm-125            /en/machine-building/qsm-215   301
/vi/cnc                    /vi/machine-building/          301
/vi/cnc/*                  /vi/machine-building/:splat    301
/en/cnc                    /en/machine-building/          301
/en/cnc/*                  /en/machine-building/:splat    301
